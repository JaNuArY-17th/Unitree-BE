  deleted_at    DateTime?       @db.Timestamp(6)
  user_id       String          @db.Uuid
  device_id     String          @db.VarChar
  device_name   String?         @db.VarChar
  device_type   String          @db.VarChar
  device_os     String?         @db.VarChar
  device_model  String?         @db.VarChar
  browser       String?         @db.VarChar
  ip_address    String?         @db.VarChar
  fcm_token     String?         @db.VarChar
  is_active     Boolean         @default(true)
  last_active   DateTime        @db.Timestamp(6)
  logged_out_at DateTime?       @db.Timestamp(6)
  users         users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_28bd79e1b3f7c1168f0904ce241")
  user_sessions user_sessions[]

  @@unique([user_id, device_id], map: "IDX_69b11f34c0f681c815fb697101")
  @@index([user_id], map: "IDX_28bd79e1b3f7c1168f0904ce24")
  @@index([device_id], map: "IDX_7c0755b2e06094d9dfb353a377")
}

model user_sessions {
  id               String       @id(map: "PK_e93e031a5fed190d4789b6bfd83") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at       DateTime     @default(now()) @db.Timestamp(6)
  updated_at       DateTime     @default(now()) @db.Timestamp(6)
  deleted_at       DateTime?    @db.Timestamp(6)
  user_id          String       @db.Uuid
  device_id        String       @db.Uuid
  access_token_id  String       @db.VarChar
  refresh_token_id String       @db.VarChar
  ip_address       String?      @db.VarChar
  user_agent       String?      @db.VarChar
  is_active        Boolean      @default(true)
  expires_at       DateTime     @db.Timestamp(6)
  last_active      DateTime     @db.Timestamp(6)
  logged_out_at    DateTime?    @db.Timestamp(6)
  user_devices     user_devices @relation(fields: [device_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_94ac98b31718fa59ce7b6201a58")
  users            users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_e9658e959c490b0a634dfc54783")

  @@index([refresh_token_id], map: "IDX_09b1908896dc0ec01e22be4fe1")
  @@index([device_id], map: "IDX_94ac98b31718fa59ce7b6201a5")
  @@index([user_id], map: "IDX_e9658e959c490b0a634dfc5478")
  @@index([access_token_id], map: "IDX_ef1bcb03c1fd6d659eecfce69f")
}

model wifi_sessions {
  id               String                    @id(map: "PK_43aa9921cb7024fcfa55723dc41") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at       DateTime                  @default(now()) @db.Timestamp(6)
  updated_at       DateTime                  @default(now()) @db.Timestamp(6)
  deleted_at       DateTime?                 @db.Timestamp(6)
  user_id          String                    @db.Uuid
  start_time       DateTime                  @db.Timestamp(6)
  end_time         DateTime?                 @db.Timestamp(6)
  duration_minutes Int                       @default(0)
  points_earned    Int                       @default(0)
  status           wifi_sessions_status_enum @default(active)
  last_heartbeat   DateTime?                 @db.Timestamp(6)
  device_id        String?                   @db.VarChar
  ip_address       String?                   @db.VarChar
  users            users                     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_4a422ae72f7e3e44dc3944a4bfd")

  @@index([user_id], map: "IDX_4a422ae72f7e3e44dc3944a4bf")
  @@index([last_heartbeat], map: "idx_wifi_last_heartbeat", where: raw("(status = 'active'::wifi_sessions_status_enum)"))
  @@index([user_id, status], map: "idx_wifi_user_status")
}

enum conversations_type_enum {
  direct
  group
}

enum friendships_status_enum {
  ACCEPTED
  PENDING
  BLOCKED
}

enum messages_type_enum {
  text
  image
  file
  system
}

enum otps_type_enum {
  email_verification
  phone_verification
  password_reset
  device_verification
  two_factor_auth
}

enum wifi_sessions_status_enum {
  active
  completed
  cancelled
}
