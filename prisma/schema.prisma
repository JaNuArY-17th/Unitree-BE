generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model airdrop_codes {
  id              String    @id(map: "PK_74632faf61a52d7ea5c47c5408f") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @default(now()) @db.Timestamp(6)
  deleted_at      DateTime? @db.Timestamp(6)
  code            String    @unique(map: "UQ_ce9360146dd5b6538d946b418b0") @db.VarChar
  resource_id     String    @db.Uuid
  amount          Int
  expiration_date DateTime? @db.Timestamp(6)
  resources       resources @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_resources_id_airdrop_codes")

  @@index([resource_id], map: "IDX_7c7062e5026da6d4b144340b21")
}

model economy_logs {
  id            String   @id(map: "PK_76a48b02d3b45c9e2eff957f4e5") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String   @db.Uuid
  resource_type String   @db.VarChar
  amount        Int
  source        String   @db.VarChar
  created_at    DateTime @default(now()) @db.Timestamp(6)
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_id_economy_logs")

  @@index([user_id], map: "IDX_3eac21abf6a30a5f662d1448b6")
}

model friendships {
  user_id_1                          String                  @db.Uuid
  user_id_2                          String                  @db.Uuid
  status                             friendships_status_enum @default(PENDING)
  created_at                         DateTime                @default(now()) @db.Timestamp(6)
  users_friendships_user_id_2Tousers users                   @relation("friendships_user_id_2Tousers", fields: [user_id_2], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_2_friendships")
  users_friendships_user_id_1Tousers users                   @relation("friendships_user_id_1Tousers", fields: [user_id_1], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_1_friendships")

  @@id([user_id_1, user_id_2], map: "PK_d982028080801d1873edde50b78")
}

model notifications {
  id         String   @id(map: "PK_6a72c3c0f683f6462415e653c3a") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  type       String   @db.VarChar
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_id_notifications")

  @@index([user_id], map: "IDX_9a8a82462cab47c73d25f49261")
}

model pvp_action_logs {
  id                                       String      @id(map: "PK_1eba3bbd73ca77e7042435dc9fd") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  attacker_id                              String      @db.Uuid
  defender_id                              String      @db.Uuid
  action_type                              String      @db.VarChar
  stolen_amount                            Int?
  target_tree_id                           String?     @db.Uuid
  was_blocked                              Boolean     @default(false)
  created_at                               DateTime    @default(now()) @db.Timestamp(6)
  users_pvp_action_logs_defender_idTousers users       @relation("pvp_action_logs_defender_idTousers", fields: [defender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_defender_id_pvp_logs")
  users_pvp_action_logs_attacker_idTousers users       @relation("pvp_action_logs_attacker_idTousers", fields: [attacker_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_attacker_id_pvp_logs")
  user_trees                               user_trees? @relation(fields: [target_tree_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_target_tree_pvp_logs")

  @@index([defender_id], map: "IDX_579f644637832b65dd551923e0")
  @@index([attacker_id], map: "IDX_81b0ad581390e3fc2e321995ab")
  @@index([target_tree_id], map: "IDX_c768916f4092aef64cc7f8b27f")
}

model resources {
  id             String           @id(map: "PK_632484ab9dff41bba94f9b7c85e") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  updated_at     DateTime         @default(now()) @db.Timestamp(6)
  deleted_at     DateTime?        @db.Timestamp(6)
  name           String           @unique(map: "UQ_f276c867b5752b7cc2c6c797b2b") @db.VarChar
  description    String?
  airdrop_codes  airdrop_codes[]
  user_resources user_resources[]
}

model spin_rewards {
  id            Int     @id(map: "PK_cc705eb228b1a7bdfcc280b4254")
  reward_type   String  @db.VarChar
  reward_amount Int
  drop_weight   Decimal @db.Decimal
}

model students {
  id         String    @id(map: "PK_7d7f07271ad4ce999880713f05e") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @default(now()) @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  student_id String    @unique(map: "UQ_ba36f3e3743f80d1cdc51020103") @db.VarChar
  full_name  String    @db.VarChar
  email      String    @unique(map: "UQ_25985d58c714a4a427ced57507b") @db.VarChar
  users      users?
}

model tasks {
  id            String       @id(map: "PK_8d12ff38fcc62aaba2cab748772") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)
  deleted_at    DateTime?    @db.Timestamp(6)
  title         String       @db.VarChar
  description   String?
  reward_type   String       @db.VarChar
  reward_amount Int
  is_daily      Boolean      @default(true)
  user_tasks    user_tasks[]
}

model trees {
  id          String       @id(map: "PK_916905d3ddf29a431776817cd8d") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at  DateTime     @default(now()) @db.Timestamp(6)
  updated_at  DateTime     @default(now()) @db.Timestamp(6)
  deleted_at  DateTime?    @db.Timestamp(6)
  name        String       @unique(map: "UQ_243b6538aaa70540db7bb1f789b") @db.VarChar
  tree_type   String       @db.VarChar
  max_level   Int          @db.SmallInt
  cost_base   Int
  cost_rate   Decimal      @db.Decimal
  oxy_base    Int?
  oxy_rate    Decimal?     @db.Decimal
  time_base   Int
  time_rate   Decimal      @db.Decimal
  perk_base   Decimal?     @db.Decimal
  perk_step   Decimal?     @db.Decimal
  slot_index  Int          @db.SmallInt
  description String
  assets_path String       @db.VarChar
  user_trees  user_trees[]
}

model user_resources {
  id          String    @id(map: "PK_9b4f73db8997f9d7210ea511237") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @default(now()) @db.Timestamp(6)
  deleted_at  DateTime? @db.Timestamp(6)
  user_id     String    @db.Uuid
  resource_id String    @db.Uuid
  balance     BigInt    @default(0)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_id_user_resources")
  resources   resources @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_resources_id_user_resources")

  @@unique([user_id, resource_id], map: "unique_user_resource")
  @@index([user_id], map: "IDX_a6aff0f62d0af51f18d6660bd1")
  @@index([resource_id], map: "IDX_d9aa67bf8ee1cd217f73bd1518")
}

model user_tasks {
  id         String    @id(map: "PK_dd5ebb5c408af74cba775bd2326") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @default(now()) @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  user_id    String    @db.Uuid
  task_id    String    @db.Uuid
  status     String    @default("PENDING") @db.VarChar
  tasks      tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tasks_id_user_tasks")
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_id_user_tasks")

  @@index([task_id], map: "IDX_67a8a20c2e44bfb84ca1a33e6d")
  @@index([user_id], map: "IDX_da349034af45568bdc0ab49314")
}

model user_trees {
  id                String            @id(map: "PK_29a7ad5fc0ac834cc704379d627") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime          @default(now()) @db.Timestamp(6)
  updated_at        DateTime          @default(now()) @db.Timestamp(6)
  deleted_at        DateTime?         @db.Timestamp(6)
  user_id           String            @db.Uuid
  tree_id           String            @db.Uuid
  level             Int               @default(1) @db.SmallInt
  is_damaged        Boolean           @default(false)
  upgrade_end_time  DateTime?         @db.Timestamp(6)
  last_harvest_time DateTime          @default(now()) @db.Timestamp(6)
  version           Int               @default(1)
  checksum          String            @db.VarChar
  damaged_at        DateTime?         @db.Timestamp(6)
  pvp_action_logs   pvp_action_logs[]
  trees             trees             @relation(fields: [tree_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_trees_id_user_trees")
  users             users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_id_user_trees")

  @@unique([user_id, tree_id], map: "unique_user_tree")
  @@index([tree_id], map: "IDX_682bd3ce09aaf8bb11f22b4956")
  @@index([user_id], map: "IDX_7e44d5d963fd277a8a4528b0c3")
}

model users {
  id                                                 String                      @id(map: "PK_a3ffb1c0c8416b9fc6f907b7433") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at                                         DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                                         DateTime                    @default(now()) @db.Timestamp(6)
  deleted_at                                         DateTime?                   @db.Timestamp(6)
  username                                           String                      @db.VarChar
  email                                              String                      @unique(map: "UQ_97672ac88f789774dd47f7c8be3") @db.VarChar
  fullname                                           String                      @db.VarChar
  student_id                                         String                      @unique(map: "UQ_4bcc4fd204f448ad671c0747ab4") @db.VarChar
  avatar                                             String?                     @db.VarChar
  role                                               String                      @db.VarChar
  spin_count                                         Int                         @default(5) @db.SmallInt
  glove_count                                        Int                         @default(0) @db.SmallInt
  watering_can_count                                 Int                         @default(0) @db.SmallInt
  shield_count                                       Int                         @default(0) @db.SmallInt
  last_spin_regen                                    DateTime?                   @db.Timestamp(6)
  total_oxy                                          BigInt                      @default(0)
  referral_code                                      String?                     @unique(map: "UQ_ba10055f9ef9690e77cf6445cba") @db.VarChar
  invited_by_code                                    String?                     @db.VarChar
  conversation_participants                          conversation_participants[]
  economy_logs                                       economy_logs[]
  friendships_friendships_user_id_2Tousers           friendships[]               @relation("friendships_user_id_2Tousers")
  friendships_friendships_user_id_1Tousers           friendships[]               @relation("friendships_user_id_1Tousers")
  messages                                           messages[]
  notifications                                      notifications[]
  pvp_action_logs_pvp_action_logs_defender_idTousers pvp_action_logs[]           @relation("pvp_action_logs_defender_idTousers")
  pvp_action_logs_pvp_action_logs_attacker_idTousers pvp_action_logs[]           @relation("pvp_action_logs_attacker_idTousers")
  user_devices                                       user_devices[]
  user_resources                                     user_resources[]
  user_sessions                                      user_sessions[]
  user_tasks                                         user_tasks[]
  user_trees                                         user_trees[]
  students                                           students                    @relation(fields: [student_id], references: [student_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_student_id_students")
  wifi_sessions                                      wifi_sessions[]

  @@index([total_oxy], map: "idx_users_total_oxy_desc")
}

model conversation_participants {
  id              String        @id(map: "PK_61b51428ad9453f5921369fbe94") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  updated_at      DateTime      @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?     @db.Timestamp(6)
  conversation_id String        @db.Uuid
  user_id         String        @db.Uuid
  joined_at       DateTime      @db.Timestamp(6)
  last_read_at    DateTime?     @db.Timestamp(6)
  is_admin        Boolean       @default(false)
  is_muted        Boolean       @default(false)
  left_at         DateTime?     @db.Timestamp(6)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_1559e8a16b828f2e836a2312800")
  users           users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_377d4041a495b81ee1a85ae026f")

  @@unique([conversation_id, user_id], map: "IDX_fdcd6405d74e797f10fa836033")
  @@index([conversation_id], map: "IDX_1559e8a16b828f2e836a231280")
  @@index([user_id], map: "IDX_377d4041a495b81ee1a85ae026")
}

model conversations {
  id                        String                      @id(map: "PK_ee34f4f7ced4ec8681f26bf04ef") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at                DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                DateTime                    @default(now()) @db.Timestamp(6)
  deleted_at                DateTime?                   @db.Timestamp(6)
  type                      conversations_type_enum     @default(direct)
  name                      String?                     @db.VarChar
  avatar                    String?                     @db.VarChar
  created_by                String                      @db.VarChar
  last_message_at           DateTime?                   @db.Timestamp(6)
  is_active                 Boolean                     @default(true)
  conversation_participants conversation_participants[]
  messages                  messages[]

  @@index([created_by], map: "IDX_81d92d15c62b3fff79c617c904")
}

model messages {
  id              String             @id(map: "PK_18325f38ae6de43878487eff986") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at      DateTime           @default(now()) @db.Timestamp(6)
  updated_at      DateTime           @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?          @db.Timestamp(6)
  conversation_id String             @db.Uuid
  sender_id       String             @db.Uuid
  type            messages_type_enum @default(text)
  content         String
  metadata        Json?
  reply_to_id     String?            @db.VarChar
  is_edited       Boolean            @default(false)
  edited_at       DateTime?          @db.Timestamp(6)
  is_deleted      Boolean            @default(false)
  users           users              @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_22133395bd13b970ccd0c34ab22")
  conversations   conversations      @relation(fields: [conversation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_3bc55a7c3f9ed54b520bb5cfe23")

  @@index([sender_id], map: "IDX_22133395bd13b970ccd0c34ab2")
  @@index([conversation_id], map: "IDX_3bc55a7c3f9ed54b520bb5cfe2")
}

model migrations {
  id        Int    @id(map: "PK_8c82d7f526340ab734260ea46be") @default(autoincrement())
  timestamp BigInt
  name      String @db.VarChar
}

model otps {
  id           String         @id(map: "PK_91fef5ed60605b854a2115d2410") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime       @default(now()) @db.Timestamp(6)
  deleted_at   DateTime?      @db.Timestamp(6)
  user_id      String         @db.VarChar
  otp_code     String         @db.VarChar
  type         otps_type_enum
  email        String?        @db.VarChar
  phone_number String?        @db.VarChar
  device_id    String?        @db.VarChar
  expires_at   DateTime       @db.Timestamp(6)
  verified_at  DateTime?      @db.Timestamp(6)
  attempts     Int            @default(0)
  max_attempts Int            @default(5)
  is_used      Boolean        @default(false)
  metadata     Json?

  @@index([user_id], map: "IDX_3938bb24b38ad395af30230bde")
  @@index([device_id], map: "IDX_583339e7ff23d9c9e16ddaa4c5")
  @@index([expires_at], map: "IDX_bd65700a251465579f9a84d76c")
}

model user_devices {
  id            String          @id(map: "PK_c9e7e648903a9e537347aba4371") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at    DateTime        @default(now()) @db.Timestamp(6)
